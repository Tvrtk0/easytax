---
import '../styles/global.css';
import { t, localizedPath, languages, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  lang?: Lang;
}

const { title = 'Easy Tax & Accounting', lang = 'en' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { path: localizedPath(lang, '/'), label: t(lang, 'nav.home') },
  { path: localizedPath(lang, '/services'), label: t(lang, 'nav.services') },
  { path: localizedPath(lang, '/articles'), label: t(lang, 'nav.articles') },
  { path: localizedPath(lang, '/contact'), label: t(lang, 'nav.contact') },
];

const homePath = localizedPath(lang, '/');

function isActive(itemPath: string, current: string) {
  const normalized = current.replace(/\/$/, '') || '/';
  const normalizedItem = itemPath.replace(/\/$/, '') || '/';
  if (normalizedItem === `${base}/${lang}`) return normalized === `${base}/${lang}`;
  return normalized.startsWith(normalizedItem);
}

const otherLang: Lang = lang === 'en' ? 'hr' : 'en';
const currentPagePath = currentPath.replace(`${base}/${lang}`, '') || '/';
const switchLangPath = localizedPath(otherLang, currentPagePath);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={t(lang, 'home.hero.subtitle')}
    />
    <link rel="alternate" hreflang="en" href={localizedPath('en', currentPagePath)} />
    <link rel="alternate" hreflang="hr" href={localizedPath('hr', currentPagePath)} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-slate-100 font-sans">
    <!-- Navigation -->
    <nav class="fixed top-6 left-4 right-4 z-50 max-w-6xl mx-auto">
      <div class="glass-card rounded-full px-6 sm:px-8 py-4 shadow-2xl">
        <div class="flex justify-between items-center">
          <!-- Logo -->
          <a href={homePath} class="flex flex-col leading-tight transition-opacity hover:opacity-70">
            <span class="text-xs text-slate-500 tracking-wide">EASY</span>
            <span class="font-semibold text-slate-900 tracking-tight">Tax & Accounting</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-2">
            {navItems.map((item) => (
              <a
                href={item.path}
                class:list={[
                  'glass-button px-6 py-2.5 rounded-full transition-all',
                  isActive(item.path, currentPath)
                    ? 'bg-white/70 text-slate-900 shadow-md'
                    : 'text-slate-700',
                ]}
              >
                {item.label}
              </a>
            ))}

            <!-- Language Switcher -->
            <a
              href={switchLangPath}
              class="glass-button px-4 py-2.5 rounded-full transition-all text-slate-700 text-sm font-medium uppercase tracking-wide"
            >
              {otherLang}
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden glass-button p-3 rounded-full"
            aria-label="Toggle menu"
          >
            <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="md:hidden mt-3 glass-card rounded-3xl shadow-2xl hidden">
        <div class="px-4 py-4 space-y-2">
          {navItems.map((item) => (
            <a
              href={item.path}
              class:list={[
                'block glass-button px-6 py-3 rounded-full transition-all',
                isActive(item.path, currentPath)
                  ? 'bg-white/70 text-slate-900 shadow-md'
                  : 'text-slate-700',
              ]}
            >
              {item.label}
            </a>
          ))}
          <a
            href={switchLangPath}
            class="block glass-button px-6 py-3 rounded-full transition-all text-slate-700 uppercase tracking-wide text-sm font-medium"
          >
            {otherLang === 'en' ? 'English' : 'Hrvatski'}
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-32">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 backdrop-blur-md bg-white/30 border-t border-white/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex flex-col leading-tight mb-4">
              <span class="text-sm text-slate-600">easy</span>
              <span class="font-semibold text-slate-900">tax & accounting</span>
            </div>
            <p class="text-slate-600 text-sm">
              {t(lang, 'footer.description')}
            </p>
          </div>

          <div>
            <h3 class="font-semibold text-slate-900 mb-4">{t(lang, 'footer.quickLinks')}</h3>
            <div class="space-y-2">
              {navItems.map((item) => (
                <a
                  href={item.path}
                  class="block text-slate-600 hover:text-slate-900 text-sm transition-colors"
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>

          <div>
            <h3 class="font-semibold text-slate-900 mb-4">{t(lang, 'footer.services')}</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>{t(lang, 'footer.legalEstablishment')}</li>
              <li>{t(lang, 'footer.businessAddress')}</li>
              <li>{t(lang, 'footer.taxCompliance')}</li>
              <li>{t(lang, 'footer.accountingServices')}</li>
            </ul>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-white/20 text-center text-sm text-slate-600">
          <p>&copy; {new Date().getFullYear()} {t(lang, 'footer.copyright')}</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
