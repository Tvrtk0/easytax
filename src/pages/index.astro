---
import Layout from '../layouts/Layout.astro';
import { t, localizedPath } from '../i18n/utils';

const lang = 'en';
---

<Layout title={t(lang, 'home.title')} lang={lang}>
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden px-4 sm:px-6 lg:px-8">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50/80 via-slate-50/50 to-indigo-50/80"></div>

    <div class="relative z-10 max-w-5xl mx-auto py-20 text-center">
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="inline-flex flex-col leading-tight items-center glass-card px-6 py-3 rounded-full">
          <span class="text-xs text-slate-500 tracking-wider">EASY</span>
          <span class="font-semibold text-slate-900 tracking-tight">Tax & Accounting</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl tracking-tight text-slate-900 font-bold" style="letter-spacing: -0.02em;" set:html={t(lang, 'home.hero.heading')} />

        <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto" style="line-height: 1.6;">
          {t(lang, 'home.hero.subtitle')}
        </p>

        <div class="flex flex-wrap gap-3 justify-center pt-4">
          <a href={localizedPath(lang, '/contact')} class="glass-button-hero px-8 py-4 rounded-full inline-flex items-center gap-2 group text-base">
            {t(lang, 'home.hero.cta')}
            <svg class="w-[18px] h-[18px] group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href={localizedPath(lang, '/services')} class="glass-button px-8 py-4 rounded-full inline-flex items-center gap-2 text-base">
            {t(lang, 'home.hero.ctaSecondary')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl mb-4 text-slate-900">{t(lang, 'home.services.heading')}</h2>
        <p class="text-xl text-slate-600 max-w-2xl mx-auto">
          {t(lang, 'home.services.subtitle')}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="glass-card p-8 rounded-3xl group hover:scale-105 transition-transform duration-300">
          <div class="glass-icon-bg w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{t(lang, 'home.services.legal.title')}</h3>
          <p class="text-slate-600">{t(lang, 'home.services.legal.desc')}</p>
        </div>

        <div class="glass-card p-8 rounded-3xl group hover:scale-105 transition-transform duration-300">
          <div class="glass-icon-bg w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{t(lang, 'home.services.address.title')}</h3>
          <p class="text-slate-600">{t(lang, 'home.services.address.desc')}</p>
        </div>

        <div class="glass-card p-8 rounded-3xl group hover:scale-105 transition-transform duration-300">
          <div class="glass-icon-bg w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{t(lang, 'home.services.tax.title')}</h3>
          <p class="text-slate-600">{t(lang, 'home.services.tax.desc')}</p>
        </div>

        <div class="glass-card p-8 rounded-3xl group hover:scale-105 transition-transform duration-300">
          <div class="glass-icon-bg w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-3">{t(lang, 'home.services.accounting.title')}</h3>
          <p class="text-slate-600">{t(lang, 'home.services.accounting.desc')}</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href={localizedPath(lang, '/services')} class="glass-button px-8 py-4 rounded-full inline-flex items-center gap-2">
          {t(lang, 'home.services.viewAll')}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl md:text-5xl mb-6 text-slate-900">{t(lang, 'home.why.heading')}</h2>
          <div class="space-y-6">
            <div class="glass-card p-6 rounded-2xl">
              <h3 class="font-semibold text-slate-900 mb-2">{t(lang, 'home.why.foreign.title')}</h3>
              <p class="text-slate-600">{t(lang, 'home.why.foreign.desc')}</p>
            </div>
            <div class="glass-card p-6 rounded-2xl">
              <h3 class="font-semibold text-slate-900 mb-2">{t(lang, 'home.why.legal.title')}</h3>
              <p class="text-slate-600">{t(lang, 'home.why.legal.desc')}</p>
            </div>
            <div class="glass-card p-6 rounded-2xl">
              <h3 class="font-semibold text-slate-900 mb-2">{t(lang, 'home.why.transparent.title')}</h3>
              <p class="text-slate-600">{t(lang, 'home.why.transparent.desc')}</p>
            </div>
          </div>
        </div>
        <div class="relative h-[600px] rounded-3xl overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1532662939046-f320195bbaf8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjcm9hdGlhJTIwZHVicm92bmlrJTIwYXJjaGl0ZWN0dXJlfGVufDF8fHx8MTc3Mzc3NjY4OXww&ixlib=rb-4.1.0&q=80&w=1080"
            alt="Croatian architecture"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="glass-card-prominent rounded-3xl p-12 md:p-16 text-center">
        <h2 class="text-4xl md:text-5xl mb-6 text-slate-900">{t(lang, 'home.cta.heading')}</h2>
        <p class="text-xl text-slate-600 mb-8 max-w-2xl mx-auto">{t(lang, 'home.cta.subtitle')}</p>
        <a href={localizedPath(lang, '/contact')} class="glass-button-hero px-8 py-4 rounded-full inline-flex items-center gap-2">
          {t(lang, 'home.cta.button')}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
