---
import Layout from '../../../layouts/Layout.astro';
import { t, localizedPath, languages, type Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  const ids = ['1', '2', '3', '4', '5', '6'];
  return languages.flatMap((lang) =>
    ids.map((id) => ({ params: { lang, id } }))
  );
}

const { lang, id } = Astro.params as { lang: Lang; id: string };

const article = {
  id,
  title: t(lang, `article.${id}.title` as any),
  date: t(lang, `article.${id}.date` as any),
  category: 'Legal',
  readTime: t(lang, `article.${id}.readTime` as any),
  author: t(lang, 'articleDetail.author'),
  image: 'https://images.unsplash.com/photo-1532662939046-f320195bbaf8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjcm9hdGlhJTIwZHVicm92bmlrJTIwYXJjaGl0ZWN0dXJlfGVufDF8fHx8MTc3Mzc3NjY4OXww&ixlib=rb-4.1.0&q=80&w=1080',
  content: t(lang, 'articleDetail.content'),
};

const relatedArticles = [
  { id: '2', category: t(lang, 'articles.cat.tax'), title: t(lang, 'articleDetail.related.1.title'), excerpt: t(lang, 'articleDetail.related.1.excerpt') },
  { id: '4', category: t(lang, 'articles.cat.accounting'), title: t(lang, 'articleDetail.related.2.title'), excerpt: t(lang, 'articleDetail.related.2.excerpt') },
  { id: '5', category: t(lang, 'articles.cat.legal'), title: t(lang, 'articleDetail.related.3.title'), excerpt: t(lang, 'articleDetail.related.3.excerpt') },
];
---

<Layout title={`${article.title} - Easy Tax & Accounting`} lang={lang}>
  <div class="py-12">
    <section class="px-4 sm:px-6 lg:px-8 mb-8">
      <div class="max-w-4xl mx-auto">
        <a href={localizedPath(lang, '/articles')} class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
          {t(lang, 'articleDetail.backToArticles')}
        </a>
      </div>
    </section>

    <section class="px-4 sm:px-6 lg:px-8 mb-12">
      <div class="max-w-5xl mx-auto">
        <div class="relative h-[400px] md:h-[500px] rounded-3xl overflow-hidden">
          <img src={article.image} alt={article.title} class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <article class="px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-wrap items-center gap-4 mb-6 text-sm text-slate-600">
          <span class="glass-button px-4 py-2 rounded-full">{article.category}</span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            {article.date}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {article.readTime}
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl mb-6 text-slate-900">{article.title}</h1>

        <div class="mb-12 pb-8 border-b border-slate-200">
          <p class="text-slate-600">
            {t(lang, 'articleDetail.by')} <span class="text-slate-900 font-medium">{article.author}</span>
          </p>
        </div>

        <div class="prose-article" set:html={article.content} />

        <div class="mt-16 pt-12 border-t border-slate-200">
          <div class="glass-card-prominent rounded-3xl p-8 md:p-12 text-center">
            <h2 class="text-2xl md:text-3xl mb-4 text-slate-900">{t(lang, 'articleDetail.cta.heading')}</h2>
            <p class="text-lg text-slate-600 mb-6">{t(lang, 'articleDetail.cta.subtitle')}</p>
            <a href={localizedPath(lang, '/contact')} class="glass-button-hero px-8 py-4 rounded-full inline-block">{t(lang, 'articleDetail.cta.button')}</a>
          </div>
        </div>
      </div>
    </article>

    <section class="px-4 sm:px-6 lg:px-8 mt-20">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl mb-8 text-slate-900">{t(lang, 'articleDetail.related')}</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedArticles.map((related) => (
            <a href={localizedPath(lang, `/articles/${related.id}`)} class="glass-card rounded-2xl p-6 group hover:scale-105 transition-transform">
              <span class="glass-button px-3 py-1 rounded-full text-xs inline-block mb-3">{related.category}</span>
              <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-slate-700 transition-colors">{related.title}</h3>
              <p class="text-sm text-slate-600">{related.excerpt}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
