---
import Layout from '../../layouts/Layout.astro';
import { t, localizedPath, languages, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const faqs = [
  { q: t(lang, 'contact.faq.1.q'), a: t(lang, 'contact.faq.1.a') },
  { q: t(lang, 'contact.faq.2.q'), a: t(lang, 'contact.faq.2.a') },
  { q: t(lang, 'contact.faq.3.q'), a: t(lang, 'contact.faq.3.a') },
  { q: t(lang, 'contact.faq.4.q'), a: t(lang, 'contact.faq.4.a') },
];
---

<Layout title={t(lang, 'contact.title')} lang={lang}>
  <div class="py-12">
    <section class="px-4 sm:px-6 lg:px-8 mb-16">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl mb-6 text-slate-900">{t(lang, 'contact.heading')}</h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">{t(lang, 'contact.subtitle')}</p>
      </div>
    </section>

    <div class="px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
          <div class="glass-card rounded-3xl p-8 md:p-12">
            <h2 class="text-3xl mb-8 text-slate-900">{t(lang, 'contact.form.heading')}</h2>

            <div id="success-message" class="glass-card-prominent rounded-2xl p-8 text-center hidden">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="text-2xl mb-2 text-slate-900">{t(lang, 'contact.form.thankYou')}</h3>
              <p class="text-slate-600">{t(lang, 'contact.form.thankYouMsg')}</p>
            </div>

            <div id="error-message" class="glass-card rounded-2xl p-6 text-center hidden border border-red-200 bg-red-50/50 mb-6">
              <p class="text-red-700 font-medium">{lang === 'hr' ? 'Nešto je pošlo po krivu. Pokušajte ponovno ili nas kontaktirajte na info@easytax.hr' : 'Something went wrong. Please try again or email us at info@easytax.hr'}</p>
            </div>

            <form id="contact-form" class="space-y-6" action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value="c25a49d5-ba16-45b6-94de-e2885ff8f0aa" />
              <input type="hidden" name="subject" value="New Contact Form Submission - easytax.hr" />
              <input type="hidden" name="from_name" value="Easy Tax Website" />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.name')}</label>
                <input type="text" id="name" name="name" required class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors" placeholder={t(lang, 'contact.form.namePlaceholder')} />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.email')}</label>
                <input type="email" id="email" name="email" required class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors" placeholder={t(lang, 'contact.form.emailPlaceholder')} />
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="company" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.company')}</label>
                  <input type="text" id="company" name="company" class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors" placeholder={t(lang, 'contact.form.companyPlaceholder')} />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.phone')}</label>
                  <input type="tel" id="phone" name="phone" class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors" placeholder={t(lang, 'contact.form.phonePlaceholder')} />
                </div>
              </div>

              <div>
                <label for="service" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.service')}</label>
                <select id="service" name="service" required class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors">
                  <option value="">{t(lang, 'contact.form.servicePlaceholder')}</option>
                  <option value="legal-establishment">{t(lang, 'contact.form.serviceLegal')}</option>
                  <option value="business-address">{t(lang, 'contact.form.serviceAddress')}</option>
                  <option value="tax-compliance">{t(lang, 'contact.form.serviceTax')}</option>
                  <option value="accounting">{t(lang, 'contact.form.serviceAccounting')}</option>
                  <option value="consultation">{t(lang, 'contact.form.serviceConsultation')}</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-2">{t(lang, 'contact.form.message')}</label>
                <textarea id="message" name="message" required rows="5" class="glass-input w-full px-4 py-3 rounded-xl outline-none focus:bg-white/50 transition-colors resize-none" placeholder={t(lang, 'contact.form.messagePlaceholder')}></textarea>
              </div>

              <button type="submit" class="glass-button-hero w-full px-8 py-4 rounded-full flex items-center justify-center gap-2 group">
                {t(lang, 'contact.form.submit')}
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
              </button>
            </form>
          </div>
      </div>
    </div>

    <section class="px-4 sm:px-6 lg:px-8 mt-20">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl mb-12 text-center text-slate-900">{t(lang, 'contact.faq.heading')}</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="glass-card rounded-2xl p-6">
              <h3 class="font-semibold text-slate-900 mb-2">{faq.q}</h3>
              <p class="text-slate-600">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-message');
    const errorMsg = document.getElementById('error-message');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="animate-pulse">Sending...</span>';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.success) {
          form.classList.add('hidden');
          successMsg?.classList.remove('hidden');
          errorMsg?.classList.add('hidden');
          form.reset();
        } else {
          errorMsg?.classList.remove('hidden');
        }
      } catch {
        errorMsg?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  </script>
</Layout>
